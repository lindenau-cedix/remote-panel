# Caddy reverse proxy for Remote Panel.
#
# Replace `panel.example.com` with your hostname. Caddy will issue and renew
# Let's Encrypt certificates automatically.

panel.example.com {
    encode zstd gzip

    # Cap request bodies. /hook is JSON < 1 KB; 4 KB leaves headroom
    # for /buttons metadata but blocks large-body DoS.
    request_body {
        max_size 4KB
    }

    # Restrict to the three endpoints that exist. Anything else gets
    # a flat 404 from Caddy itself and never reaches FastAPI.
    # Caddy v2 doesn't have a `not` directive — instead we list the
    # allowed shapes in mutually-exclusive handle blocks and catch
    # everything else in the final, matcher-less handle.
    @post_hook   method POST path /hook
    @get_health  method GET  path /healthz
    @get_buttons method GET  path /buttons

    log {
        output file /var/log/caddy/remote-panel.log {
            roll_size 10mb
            roll_keep 5
        }
    }

    route {
        # reverse_proxy reads X-Forwarded-For automatically and sets
        # X-Real-IP / Forwarded headers as needed; no header_up needed
        # for the rate limiter to key on the real client IP.
        # See server/app.py::_client_ip.
        reverse_proxy @post_hook   127.0.0.1:8088
        reverse_proxy @get_health  127.0.0.1:8088
        reverse_proxy @get_buttons 127.0.0.1:8088

        # Catch-all: anything that didn't match the three allowed
        # shapes gets a flat 404 at the edge.
        respond "404 not found" 404
    }
}