# Remote Panel — runtime configuration.
#
# Copy this file to .env and edit. NEVER commit the populated .env.
#
#   cp deploy/docker/.env.example deploy/docker/.env
#   chmod 0600 deploy/docker/.env
#   $EDITOR deploy/docker/.env
#
# The PANEL_SECRET you put here is the only secret the phone needs.
# Generate it with:
#
#   openssl rand -hex 32

# 64 hex characters. Must be at least 16 chars (validator rejects shorter).
PANEL_SECRET=

# Hostname the Android app will reach. Caddy will issue a Let's Encrypt
# cert for this name, so it must resolve to this machine's public IP
# BEFORE `docker compose up`.
PANEL_HOSTNAME=panel.example.com

# Optional. Defaults to "info". One of: debug, info, warning, error.
PANEL_LOG_LEVEL=info