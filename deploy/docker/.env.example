# Remote Panel — runtime configuration.
#
# Copy this file to .env and edit. NEVER commit the populated .env.
#
#   cp deploy/docker/.env.example deploy/docker/.env
#   chmod 0600 deploy/docker/.env
#   $EDITOR deploy/docker/.env
#
# The PANEL_SECRET you put here is the only secret the phone needs.
# Generate it with:
#
#   openssl rand -hex 32

# 64 hex characters. Must be at least 16 chars (validator rejects shorter).
PANEL_SECRET=

# Hostname the Android app will reach. Caddy will issue a Let's Encrypt
# cert for this name, so it must resolve to this machine's public IP
# BEFORE `docker compose up`.
PANEL_HOSTNAME=panel.example.com

# Optional. Defaults to "info". One of: debug, info, warning, error.
PANEL_LOG_LEVEL=info

# ---- SSH-wrap mode (Plan B) ----------------------------------------------
#
# Leave all three empty to run in legacy mode (commands execute inside
# the panel-host sidecar via `docker exec`). Set all three to enable
# SSH-wrap mode (commands execute on the host via SSH, with the host's
# authorized_keys pinning the exact argv via the `command=` directive).
#
# See deploy/docker/README.md § Using SSH-wrap mode for the full setup,
# including per-command key generation, authorized_keys pinning, and
# the matching `ssh:` block in whitelist.json.
#
# PANEL_SSH_TARGET_HOST=localhost
# PANEL_SSH_TARGET_USER=root
# PANEL_SSH_KEY_PATH=/etc/panel/ssh/sim24-bot.ed25519